<Window x:Class="LeetCodeManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LeetCodeManager.ViewModels"
        xmlns:conv="clr-namespace:LeetCodeManager.Converters"
        Title="LeetCode Study Manager"
        Height="720" Width="1280"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:StatusToForegroundConverter          x:Key="StatusFg"/>
        <conv:DifficultyToForegroundConverter      x:Key="DiffFg"/>
        <conv:NonEmptyStringToVisibilityConverter  x:Key="NonEmptyVis"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding ClearAllFiltersCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ═══════════════════════ HEADER ═══════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource Header}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <!-- App title -->
                <TextBlock DockPanel.Dock="Left"
                           Text="🧩 LeetCode Study Manager"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource Text}"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <!-- Stats (right-aligned) -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <Border Background="#1E3A2E" CornerRadius="4" Padding="10,4" Margin="4,0">
                        <TextBlock Foreground="{StaticResource SolvedFg}" FontSize="12">
                            <Run Text="✓ Solved: "/><Run Text="{Binding SolvedCount}"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#3A2010" CornerRadius="4" Padding="10,4" Margin="4,0">
                        <TextBlock Foreground="{StaticResource ReviewFg}" FontSize="12">
                            <Run Text="⚑ Review: "/><Run Text="{Binding NeedReviewCount}"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#2D2D30" CornerRadius="4" Padding="10,4" Margin="4,0">
                        <TextBlock Foreground="{StaticResource SubText}" FontSize="12">
                            <Run Text="Total: "/><Run Text="{Binding TotalCount}"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Quick-filter buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⚑  Mark Need Review"
                            Command="{Binding ToggleNeedReviewCommand}"
                            Style="{StaticResource RoundBtn}"
                            Background="#7A3800"
                            Foreground="{StaticResource ReviewFg}"
                            Margin="4,0"/>
                    <Button Content="✓  Solved"
                            Command="{Binding ToggleSolvedCommand}"
                            Style="{StaticResource RoundBtn}"
                            Background="#1E3A2E"
                            Foreground="{StaticResource SolvedFg}"
                            Margin="4,0"/>

                    <!-- Active filter badge -->
                    <Border Background="#264F78" CornerRadius="4" Padding="8,4" Margin="10,0,0,0"
                            Visibility="{Binding ActiveQuickFilterLabel, Converter={StaticResource NonEmptyVis}}">
                        <TextBlock Foreground="#9CDCFE" FontSize="12" VerticalAlignment="Center"
                                   Text="{Binding ActiveQuickFilterLabel, StringFormat='🔍 {0}'}"/>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════ FILTER BAR ═══════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="12,7">
            <DockPanel>
                <!-- Clear + result count (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource SubText}" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0">
                        <Run Text="Showing "/><Run Text="{Binding FilteredCount}"/>
                        <Run Text=" / "/><Run Text="{Binding TotalCount}"/>
                    </TextBlock>
                    <Button Content="✕  Clear Filters"
                            Command="{Binding ClearAllFiltersCommand}"
                            Style="{StaticResource RoundBtn}"
                            Background="#4C1A1A"
                            Foreground="#F48771"
                            Padding="10,6"/>
                </StackPanel>

                <!-- Left filter controls -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Search box -->
                    <TextBox Width="220"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,8,0">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="🔍  Search title…"
                                                                   Foreground="#666" Padding="7,5"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Difficulty -->
                    <ComboBox SelectedValue="{Binding SelectedDifficulty}"
                            SelectedValuePath="Content"
                            Width="120" Margin="0,0,8,0"
                            Foreground="Black">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>

                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Easy"/>
                        <ComboBoxItem Content="Medium"/>
                        <ComboBoxItem Content="Hard"/>
                    </ComboBox>

                    <!-- Status -->
                    <ComboBox SelectedValue="{Binding SelectedStatus}"
                            SelectedValuePath="Content"
                            Width="150" Margin="0,0,8,0"
                            Foreground="Black">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>

                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Solved"/>
                        <ComboBoxItem Content="Need Review"/>
                    </ComboBox>

                    <!-- Problem List -->
                    <ComboBox ItemsSource="{Binding ProblemLists}"
                            SelectedItem="{Binding SelectedProblemList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Width="160"
                            Margin="0,0,8,0"
                            Foreground="Black">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <!-- Topics popup button -->
                    <Grid Margin="0,0,8,0">
                        <ToggleButton x:Name="TopicToggle"
                                      Content="{Binding SelectedTopicsText}"
                                      Width="160"
                                      Style="{StaticResource TogglePopupBtn}"/>
                        <Popup IsOpen="{Binding IsChecked, ElementName=TopicToggle, Mode=TwoWay}"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               PlacementTarget="{Binding ElementName=TopicToggle}"
                               Placement="Bottom">
                            <Border Background="{StaticResource Panel}"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    MaxHeight="280"
                                    MinWidth="160"
                                    Effect="{x:Null}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding TopicFilters}" Margin="4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Foreground="{StaticResource Text}"
                                                          Margin="4,3" Padding="3,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════ STATUS BAR ═══════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Header}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock Foreground="{StaticResource SubText}" FontSize="11"
                       VerticalAlignment="Center"
                       Text="Tip: Press Esc to clear all filters. Click a Status cell once to edit."/>
        </Border>

        <!-- ═══════════════════════ DATA GRID ════════════════════ -->
        <DataGrid x:Name="ProblemsGrid"
                ItemsSource="{Binding ProblemsView}"
                SelectedItem="{Binding SelectedProblem, Mode=TwoWay}"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                IsReadOnly="False"
                SelectedCellsChanged="ProblemsGrid_SelectedCellsChanged"
                HeadersVisibility="Column"
                RowHeaderWidth="0">

            <DataGrid.RowHeaderStyle>
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="Background" Value="{StaticResource Bg}"/>
                    <Setter Property="Foreground" Value="{StaticResource Text}"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.RowHeaderStyle>

            <DataGrid.RowHeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextAlignment="Center"/>
                </DataTemplate>
            </DataGrid.RowHeaderTemplate>

            <DataGrid.Columns>
                <DataGridTextColumn Header=""
                                Binding="{Binding RowNumber}"
                                Width="45"
                                IsReadOnly="True">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
                <!-- # ── Title -->
                <DataGridTextColumn Header="Title"
                                    Binding="{Binding Master.Title}"
                                    Width="230" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- # ── Difficulty -->
                <DataGridTemplateColumn Header="Difficulty" Width="88" IsReadOnly="True" SortMemberPath="Master.Difficulty">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Master.Difficulty}"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Master.Difficulty, Converter={StaticResource DiffFg}}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- # ── Topics -->
                <DataGridTextColumn Header="Topics"
                                    Binding="{Binding TopicsDisplay}"
                                    Width="210" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- # ── Status (editable ComboBox) -->
                <DataGridTemplateColumn Header="Status" Width="145" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}"
                                       Foreground="{Binding Status, Converter={StaticResource StatusFg}}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" Padding="8,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedValue="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Content"
                                    IsDropDownOpen="True"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    Foreground="Black">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="White"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                                <ComboBoxItem Content="Solved"/>
                                <ComboBoxItem Content="Need Review"/>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- # ── Last Tried Date -->
                <DataGridTextColumn Header="Last Tried"
                                    Binding="{Binding LastSolvedDateDisplay}"
                                    Width="105" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- # ── Lists count -->
                <DataGridTextColumn Header="Lists"
                                    Binding="{Binding Master.ListCount}"
                                    Width="55" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#9CDCFE"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- # ── URL (Hyperlink) -->
                <DataGridTemplateColumn Header="Link" Width="60" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Hyperlink NavigateUri="{Binding Master.Url}"
                                           RequestNavigate="Hyperlink_RequestNavigate"
                                           Foreground="#4DA8DA">
                                    <Run Text="Open"/>
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- # ── Included In -->
                <DataGridTextColumn Header="Included In"
                                    Binding="{Binding IncludedInDisplay}"
                                    Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>

        </DataGrid>

    </DockPanel>
</Window>
